# ============================================================
# Variables d'environnement — Pipeline ETL Commerce Congo
# Copier ce fichier en .env et renseigner les valeurs réelles
# NE JAMAIS COMMITTER le fichier .env dans git !
# ============================================================

# ─── Entrepôt de données (PostgreSQL destination) ─────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=entrepot_commerce
DB_USER=etl_user
DB_PASSWORD=votre_mot_de_passe_securise

# ─── Base de données source (ERP/POS) ────────────────────────────────────
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=erp_commerce
SOURCE_DB_USER=readonly_user
SOURCE_DB_PASSWORD=votre_mot_de_passe_source

# ─── Airflow ──────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=votre_cle_secrete_airflow
AIRFLOW_EMAIL_ALERT=alertes@commerce-congo.cg

# ─── dbt ──────────────────────────────────────────────────────────────────
DBT_PASSWORD=votre_mot_de_passe_dbt

# ─── pgAdmin ──────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@commerce-congo.cg
PGADMIN_PASSWORD=votre_mot_de_passe_pgadmin

# ─── API externe (si applicable) ─────────────────────────────────────────
API_KEY=votre_cle_api

# ─── Email SMTP (alertes pipeline) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=pipeline@commerce-congo.cg
SMTP_PASSWORD=votre_mot_de_passe_smtp

# ─── Environnement ────────────────────────────────────────────────────────
ENVIRONNEMENT=dev
PYTHON_PATH=/app
